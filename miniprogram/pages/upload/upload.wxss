/**pages/upload/upload.wxss**/
.container {
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #a0a0a0;
}

.upload-area {
  width: 100%;
  height: 500rpx;
  background: #1a1a2e;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  border: 2rpx dashed #333333;
  position: relative;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.upload-text {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #444444;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
}

.change-btn {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

.tips {
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.tips-title {
  font-size: 26rpx;
  color: #00d4aa;
  display: block;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.tip-item {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.8;
}

.generate-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #00d4aa, #00a3cc);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
}

.generate-button[disabled] {
  background: #333333;
  color: #666666;
}

.generate-button::after {
  border: none;
}
