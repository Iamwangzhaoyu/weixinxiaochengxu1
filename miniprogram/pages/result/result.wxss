/**pages/result/result.wxss**/
.container {
  padding: 40rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #a0a0a0;
}

.style-scroll {
  margin-bottom: 40rpx;
}

.style-list {
  display: flex;
  gap: 24rpx;
  padding: 10rpx 0;
}

.style-item {
  flex-shrink: 0;
  width: 160rpx;
  text-align: center;
}

.style-item.selected .style-preview {
  border-color: #00d4aa;
}

.style-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #333333;
  position: relative;
  margin-bottom: 12rpx;
}

.style-thumb {
  width: 100%;
  height: 100%;
}

.watermark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-30deg);
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  white-space: nowrap;
}

.style-name {
  font-size: 22rpx;
  color: #888888;
}

.style-item.selected .style-name {
  color: #00d4aa;
}

.compare-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.compare-item {
  flex: 1;
  text-align: center;
  position: relative;
}

.compare-label {
  font-size: 24rpx;
  color: #666666;
  display: block;
  margin-bottom: 16rpx;
}

.compare-image {
  width: 320rpx;
  height: 400rpx;
  border-radius: 16rpx;
  background: #1a1a2e;
}

.compare-arrow {
  font-size: 40rpx;
  color: #00d4aa;
  padding: 0 20rpx;
}

.watermark-large {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  background: rgba(0, 0, 0, 0.3);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.unlock-section {
  text-align: center;
}

.unlock-title {
  font-size: 30rpx;
  color: #ffffff;
  display: block;
  margin-bottom: 32rpx;
}

.unlock-options {
  display: flex;
  gap: 24rpx;
}

.option-card {
  flex: 1;
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  border: 2rpx solid #333333;
  position: relative;
}

.option-card.premium {
  border-color: #00d4aa;
  background: #1a2e2e;
}

.option-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  background: #00d4aa;
  color: #000000;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: bold;
}

.option-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.option-title {
  font-size: 28rpx;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.option-desc {
  font-size: 22rpx;
  color: #888888;
}

.unlocked-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.download-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #00d4aa, #00a3cc);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
}

.download-button::after {
  border: none;
}

.share-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: transparent;
  color: #00d4aa;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: 2rpx solid #00d4aa;
}
