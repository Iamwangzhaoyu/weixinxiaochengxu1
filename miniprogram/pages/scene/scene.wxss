/**pages/scene/scene.wxss**/
.container {
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #a0a0a0;
}

.scene-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.scene-item {
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.scene-item.selected {
  border-color: #00d4aa;
  background: #1a2e2e;
}

.scene-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.scene-name {
  font-size: 28rpx;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.scene-desc {
  font-size: 22rpx;
  color: #666666;
}

.next-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #00d4aa, #00a3cc);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
}

.next-button[disabled] {
  background: #333333;
  color: #666666;
}

.next-button::after {
  border: none;
}
