/**pages/index/index.wxss**/
.container {
  padding: 40rpx;
}

.hero {
  text-align: center;
  margin-bottom: 60rpx;
}

.hero-image {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.hero-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: #a0a0a0;
}

.scene-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.scene-card {
  flex: 1;
  min-width: 300rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  overflow: hidden;
}

.scene-thumb {
  width: 100%;
  height: 200rpx;
}

.scene-info {
  padding: 20rpx;
}

.scene-name {
  font-size: 28rpx;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.scene-price {
  font-size: 24rpx;
  color: #00d4aa;
}

.social-proof {
  text-align: center;
  margin-bottom: 40rpx;
}

.proof-text {
  font-size: 24rpx;
  color: #666666;
}

.cta-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #00d4aa, #00a3cc);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
}

.cta-button::after {
  border: none;
}
